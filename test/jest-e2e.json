{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@app/blockchain-payment(|/.*)$": "<rootDir>/../libs/blockchain-payment/src/$1",
    "^@app/payment(|/.*)$": "<rootDir>/../libs/payment/src/$1"
  }
}