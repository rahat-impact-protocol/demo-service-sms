generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Registry {
  id        String   @id @default("main")
  baseUrl  String
  publicKey String
  createdAt DateTime @default(now())
  privateKey String?
}


model SmsProvider{
uuid      String @id @default(uuid())
name      String 
value     Json @db.JsonB() 
pricePerApi String ?
createdAt  DateTime @default(now())
updatedAt  DateTime? @updatedAt
}