{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true
  },
  "projects": {
    "blockchain-payment": {
      "type": "library",
      "root": "libs/blockchain-payment",
      "entryFile": "index",
      "sourceRoot": "libs/blockchain-payment/src",
      "compilerOptions": {
        "tsConfigPath": "libs/blockchain-payment/tsconfig.lib.json"
      }
    },
    "payment": {
      "type": "library",
      "root": "libs/payment",
      "entryFile": "index",
      "sourceRoot": "libs/payment/src",
      "compilerOptions": {
        "tsConfigPath": "libs/payment/tsconfig.lib.json"
      }
    }
  }
}